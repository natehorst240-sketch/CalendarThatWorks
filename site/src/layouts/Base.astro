---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'WorksCalendar — Resource Scheduling for Serious Operations',
  description = 'The embeddable calendar built for teams that schedule people, assets, and logistics — not just events.',
} = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-[#0a0a0f] text-white font-sans antialiased">
    <slot />
  </body>
</html>
