{
  "name": "works-calendar",
  "version": "0.1.0",
  "description": "Drop-in embeddable React calendar with filter pills, hover cards, Excel export, and owner config panel",
  "type": "module",
  "types": "./src/index.d.ts",
  "main": "./dist/works-calendar.umd.js",
  "module": "./dist/works-calendar.es.js",
  "exports": {
    ".": {
      "import": "./dist/works-calendar.es.js",
      "require": "./dist/works-calendar.umd.js"
    },
    "./styles": "./dist/style.css",
    "./styles/aviation": "./dist/themes/aviation.css",
    "./styles/soft": "./dist/themes/soft.css",
    "./styles/minimal": "./dist/themes/minimal.css",
    "./styles/corporate": "./dist/themes/corporate.css",
    "./styles/forest": "./dist/themes/forest.css",
    "./styles/ocean": "./dist/themes/ocean.css",
    "./themes": "./dist/works-calendar.es.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "vite --config vite.demo.config.js",
    "build": "vite build",
    "build:demo": "vite build --config vite.demo.config.js",
    "preview": "vite preview --config vite.demo.config.js"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "dependencies": {
    "date-fns": "^3.6.0",
    "lucide-react": "^0.378.0"
  },
  "optionalDependencies": {
    "@supabase/supabase-js": "^2.43.4",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^4.2.1",
    "happy-dom": "^20.8.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^5.2.11",
    "vitest": "^4.1.4"
  }
}
