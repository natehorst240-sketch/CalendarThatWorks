{
  "name": "works-calendar",
  "version": "1.0.0",
  "description": "Drop-in embeddable React calendar with filtering, scheduling workflows, themes, and external-form support.",
  "license": "MIT",
  "type": "module",
  "module": "./dist/works-calendar.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/works-calendar.es.js"
    },
    "./styles": {
      "import": "./dist/style.css",
      "default": "./dist/style.css"
    },
    "./styles/aviation": {
      "import": "./dist/themes/aviation.css",
      "default": "./dist/themes/aviation.css"
    },
    "./styles/soft": {
      "import": "./dist/themes/soft.css",
      "default": "./dist/themes/soft.css"
    },
    "./styles/minimal": {
      "import": "./dist/themes/minimal.css",
      "default": "./dist/themes/minimal.css"
    },
    "./styles/corporate": {
      "import": "./dist/themes/corporate.css",
      "default": "./dist/themes/corporate.css"
    },
    "./styles/forest": {
      "import": "./dist/themes/forest.css",
      "default": "./dist/themes/forest.css"
    },
    "./styles/ocean": {
      "import": "./dist/themes/ocean.css",
      "default": "./dist/themes/ocean.css"
    },
    "./styles/family": {
      "import": "./dist/themes/family/index.css",
      "default": "./dist/themes/family/index.css"
    },
    "./styles/family/canvas": {
      "import": "./dist/themes/family/canvas.css",
      "default": "./dist/themes/family/canvas.css"
    },
    "./styles/family/corporate": {
      "import": "./dist/themes/family/corporate.css",
      "default": "./dist/themes/family/corporate.css"
    },
    "./styles/family/industrial": {
      "import": "./dist/themes/family/industrial.css",
      "default": "./dist/themes/family/industrial.css"
    },
    "./styles/family/grid": {
      "import": "./dist/themes/family/grid.css",
      "default": "./dist/themes/family/grid.css"
    },
    "./styles/family/ops": {
      "import": "./dist/themes/family/ops.css",
      "default": "./dist/themes/family/ops.css"
    },
    "./styles/family/neon": {
      "import": "./dist/themes/family/neon.css",
      "default": "./dist/themes/family/neon.css"
    },
    "./themes": {
      "types": "./dist/index.d.ts",
      "import": "./dist/works-calendar.es.js"
    },
    "./dist/*": "./dist/*"
  },
  "engines": {
    "node": ">=18"
  },
  "sideEffects": [
    "**/*.css",
    "**/*.module.css"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/workscalendar/calendarthatworks.git"
  },
  "homepage": "https://workscalendar.com",
  "bugs": {
    "url": "https://github.com/workscalendar/calendarthatworks/issues"
  },
  "scripts": {
    "dev": "npm --prefix demo/app run dev",
    "dev:embed": "vite --config vite.demo.config.ts",
    "build:demo": "vite build --config vite.demo.config.ts",
    "build:app": "npm --prefix demo/app run build",
    "test": "cross-env TZ=UTC vitest run",
    "test:watch": "cross-env TZ=UTC vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "build": "vite build",
    "type-check": "tsc --noEmit --project tsconfig.build.json",
    "type-check:watch": "tsc --noEmit --project tsconfig.build.json --watch",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "package:check": "attw --pack . --profile esm-only --entrypoints . ./themes",
    "check": "npm run type-check && npm run lint && npm run test",
    "prepublishOnly": "npm run build && npm run package:check"
  },
  "peerDependencies": {
    "@supabase/supabase-js": "^2.0.0",
    "date-fns": "^3.6.0",
    "exceljs": "^4.4.0",
    "lucide-react": ">=0.378.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "@supabase/supabase-js": {
      "optional": true
    },
    "exceljs": {
      "optional": true
    }
  },
  "dependencies": {
    "fuse.js": "^7.3.0"
  },
  "overrides": {
    "exceljs": {
      "archiver": "^7.0.1",
      "fast-csv": "^5.0.2",
      "unzipper": "^0.12.3",
      "uuid": "^11.0.5"
    },
    "archiver-utils": {
      "glob": "^11.0.0"
    }
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@playwright/test": "^1.60.0",
    "@supabase/supabase-js": "^2.0.0",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.19.39",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^4.1.5",
    "cross-env": "^10.1.0",
    "date-fns": "^3.6.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "exceljs": "^4.4.0",
    "happy-dom": "^20.8.9",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.4",
    "lucide-react": "^0.378.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.2",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.4"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "eslint --max-warnings=0 --no-warn-ignored"
    ]
  },
  "keywords": [
    "calendar",
    "scheduler",
    "react-calendar",
    "team-scheduling",
    "pto",
    "drag-and-drop",
    "timeline",
    "agenda"
  ]
}
