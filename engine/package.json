{
  "name": "works-calendar-engine",
  "version": "0.1.0",
  "description": "Framework-agnostic scheduling state machine with rule-based conflict detection.",
  "license": "MIT",
  "author": "Nathan Horstmeier <natehorst240@gmail.com>",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WorksCalendar/Engine.git"
  },
  "bugs": {
    "url": "https://github.com/WorksCalendar/Engine/issues"
  },
  "homepage": "https://github.com/WorksCalendar/Engine#readme",
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit -p tsconfig.build.json",
    "check": "npm run type-check && npm test"
  },
  "engines": {
    "node": ">=20"
  },
  "peerDependencies": {
    "date-fns": "^3.6.0 || ^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.39",
    "date-fns": "^3.6.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4"
  },
  "keywords": [
    "scheduling",
    "calendar",
    "conflict-detection",
    "state-machine",
    "framework-agnostic"
  ]
}
